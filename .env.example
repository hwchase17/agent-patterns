# Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys

# LangSmith API Key (Required)
# Get your API key from: https://smith.langchain.com/settings
# This is required for LangGraph deployment and tracing
LANGSMITH_API_KEY=your_langsmith_api_key_here

# OpenAI API Key (Required if using OpenAI models)
# Get your API key from: https://platform.openai.com/api-keys
# The agent is configured to use OpenAI GPT-4o-mini by default
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Alternative to OpenAI)
# Get your API key from: https://console.anthropic.com/settings/keys
# Uncomment and use this if you prefer Anthropic models
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit the .env file with your actual API keys
# 3. Never commit the .env file to version control
# 4. The .env file is already included in .gitignore

# Note: At minimum, you need LANGSMITH_API_KEY and either OPENAI_API_KEY or ANTHROPIC_API_KEY

